# Anthropic API key — get yours at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Resend API key — get yours at resend.com
RESEND_API_KEY=re_...

# Sender address — use onboarding@resend.dev for testing (sends only to your Resend account email)
# To send to any address, verify a domain at resend.com/domains and use an address from that domain
EMAIL_FROM=onboarding@resend.dev

# Recipient address
EMAIL_TO=you@example.com
